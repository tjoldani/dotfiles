{
  "layer": "top",
  "position": "top",
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": [],
  "modules-right": ["temperature", "cpu", "memory", "pulseaudio", "network", "clock", "custom/power"],

  "hyprland/window": {
    "max-length": 50,
    "separate-outputs": true
  },

  "hyprland/workspaces": {
    "format": "{id}",
    "on-click": "activate",
    "all-outputs": false,
    "disable-scroll": false
  },

  "custom/power": {
    "format": "  ",
    "tooltip": "Power Menu",
    "on-click": "~/.config/waybar/scripts/power.sh"
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%A %B %e, %Y}"
  },

  "cpu": {
    "format": "  {usage}%",
    "tooltip-format": "{usage0}%",
    "interval": 5
  },

  "memory": {
    "format": "󰍛 {percentage}%",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
    "interval": 30
  },

  "temperature": {
    "critical-threshold": 90,
    "format": "{icon} {temperatureC}°C ",
    "tooltip-format": "{temperatureF}°F",
    "format-icons": [""]
  },

  "network": {
    "interface": "wlo1",
    "format-wifi": " ",
    "format-ethernet": "  {ipaddr}",
    "format-disconnected": "󰤭 Disconnected",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}\n{ipaddr}",
    "on-click": "~/.config/waybar/scripts/wifi.sh"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "  muted",
    "format-icons": {
      "default": [" ", " ", " "]
    },
    "on-click": "hyprpwcenter"
  }
}

